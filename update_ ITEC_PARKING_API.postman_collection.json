    {
      "name": "Databases",
      "item": [
        {
          "name": "Get Databases",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization","value": "Bearer {{JWT_TOKEN}}"}
            ],
            "url": {
              "raw": "{{base_url}}/databases",
              "host": ["{{base_url}}"],
              "path": ["databases"]
            },
            "description": "Admin-only: get all configured external databases."
          }
        },
        {
          "name": "Get Database By ID",
          "request": {
            "method": "GET",
            "header": [
