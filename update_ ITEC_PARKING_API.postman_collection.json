    {
      "name": "Payment",
      "item": [
        {
          "name": "Lookup Plate (all parkings)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type","value": "application/json"},
              {"key": "Authorization","value": "Bearer {{JWT_TOKEN}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plate_no\": \"RAD123A\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/payment/lookup",
              "host": ["{{base_url}}"],
              "path": ["payment","lookup"]
            },
            "description": "Search every registered parking database for a plate and report what is owed. Use this when the client does not know which parking their vehicle is in. If the client already knows the parking, pass db_id (and optionally parking_id) instead - see 'Lookup Plate (known parking)' - to skip the cross-database scan. Blocks postpaid/company-account vehicles from self-payment (payable: false)."
          },
          "response": [
            {
              "name": "200 Success - active session",
              "body": "{\n  \"status\": \"success\",\n  \"matches\": [\n    {\n      \"db_id\": \"1\",\n      \"db_name\": \"Central Parking Database\",\n      \"parking_id\": \"101\",\n      \"plate_no\": \"RAD123A\",\n      \"p_in_id\": \"9001\",\n      \"payment_type\": \"checkout\",\n      \"entre_time\": \"2023-05-15 10:15:00\",\n      \"hours\": 3,\n      \"amount_owed\": 1500,\n      \"payable\": true\n    }\n  ]\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "200 Success - outstanding credit",
              "body": "{\n  \"status\": \"success\",\n  \"matches\": [\n    {\n      \"db_id\": \"1\",\n      \"db_name\": \"Central Parking Database\",\n      \"parking_id\": \"101\",\n      \"plate_no\": \"RAD123A\",\n      \"p_in_id\": \"8990\",\n      \"payment_type\": \"credit\",\n      \"entre_time\": \"2023-05-10 08:00:00\",\n      \"amount_owed\": 2500,\n      \"payable\": true\n    }\n  ]\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "200 Success - postpaid (blocked)",
              "body": "{\n  \"status\": \"success\",\n  \"matches\": [\n    {\n      \"db_id\": \"1\",\n      \"db_name\": \"Central Parking Database\",\n      \"parking_id\": \"101\",\n      \"plate_no\": \"RAD123A\",\n      \"payable\": false,\n      \"reason\": \"postpaid\",\n      \"message\": \"This vehicle is on a postpaid/company account. Contact the attendant to settle.\"\n    }\n  ]\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "404 Not Found",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Plate not found or not currently parked\"\n}",
              "status": "Not Found",
              "code": 404
            },
            {
              "name": "401 Unauthorized",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Authentication required\"\n}",
              "status": "Unauthorized",
              "code": 401
            }
          ]
        },
        {
          "name": "Lookup Plate (known parking)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type","value": "application/json"},
              {"key": "Authorization","value": "Bearer {{JWT_TOKEN}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plate_no\": \"RAD123A\",\n  \"db_id\": 1,\n  \"parking_id\": 101\n}"
            },
            "url": {
              "raw": "{{base_url}}/payment/lookup",
              "host": ["{{base_url}}"],
              "path": ["payment","lookup"]
            },
            "description": "Same endpoint as plain lookup, but when the client already knows which parking they're in (db_id, optionally parking_id), passing it skips the all-tenant scan and queries that single database directly - faster and avoids ambiguity if the same plate happens to exist in more than one tenant."
          },
          "response": [
            {
              "name": "200 Success",
              "body": "{\n  \"status\": \"success\",\n  \"matches\": [\n    {\n      \"db_id\": \"1\",\n      \"db_name\": \"Central Parking Database\",\n      \"parking_id\": \"101\",\n      \"plate_no\": \"RAD123A\",\n      \"p_in_id\": \"9001\",\n      \"payment_type\": \"checkout\",\n      \"entre_time\": \"2023-05-15 10:15:00\",\n      \"hours\": 3,\n      \"amount_owed\": 1500,\n      \"payable\": true\n    }\n  ]\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "404 Not Found",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Plate not found or not currently parked\"\n}",
              "status": "Not Found",
              "code": 404
            }
          ]
        },
        {
          "name": "Initiate Payment",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type","value": "application/json"},
              {"key": "Authorization","value": "Bearer {{JWT_TOKEN}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"db_id\": 1,\n  \"plate_no\": \"RAD123A\",\n  \"p_in_id\": 9001,\n  \"payment_type\": \"checkout\",\n  \"payer_phone\": \"+250700000000\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/payment/initiate",
              "host": ["{{base_url}}"],
              "path": ["payment","initiate"]
            },
            "description": "Initiate a mobile-money self-payment for a plate/session found via /payment/lookup. db_id, plate_no, p_in_id and payment_type ('checkout' or 'credit') should come from the lookup response. payer_phone is the number that will receive the MoMo prompt - it must be explicitly supplied by the client and is not defaulted to their account phone, since anyone with the plate number can look it up and pay. The amount is always recomputed server-side from the current session/credit state; any client-submitted amount is ignored. Poll /payment/status/{db_id}/{req_ref} afterward to track completion."
          },
          "response": [
            {
              "name": "202 Pending",
              "body": "{\n  \"status\": \"pending\",\n  \"message\": \"Payment initiated. Please approve on your phone.\",\n  \"req_ref\": \"3fa1c2b4-5678-4abc-9def-0123456789ab\",\n  \"db_id\": 1,\n  \"transaction_id\": \"TX123456\"\n}",
              "status": "Accepted",
              "code": 202
            },
            {
              "name": "400 Error - nothing owed",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Nothing owed for this plate\"\n}",
              "status": "Bad Request",
              "code": 400
            },
            {
              "name": "403 Forbidden - postpaid",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"This vehicle is on a postpaid/company account and cannot be self-paid\"\n}",
              "status": "Forbidden",
              "code": 403
            },
            {
              "name": "404 Not Found",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Plate not currently parked or credited\"\n}",
              "status": "Not Found",
              "code": 404
            }
          ]
        },
        {
          "name": "Check Payment Status",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization","value": "Bearer {{JWT_TOKEN}}"}],
            "url": {
              "raw": "{{base_url}}/payment/status/1/3fa1c2b4-5678-4abc-9def-0123456789ab",
              "host": ["{{base_url}}"],
              "path": ["payment","status","1","3fa1c2b4-5678-4abc-9def-0123456789ab"]
            },
            "description": "Poll the status of a self-payment attempt by db_id and req_ref (both returned from /payment/initiate). On the gateway reporting SUCCESSFUL, this also triggers the same server-side settlement (closing the parking session or paying down credit) as the gateway callback would, guarded so it only runs once even if both race each other."
          },
          "response": [
            {
              "name": "200 Success - pending",
              "body": "{\n  \"status\": \"success\",\n  \"data\": {\n    \"status\": \"PENDING\",\n    \"amount\": 1500,\n    \"charged_amount\": 0\n  }\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "200 Success - successful",
              "body": "{\n  \"status\": \"success\",\n  \"data\": {\n    \"status\": \"SUCCESSFUL\",\n    \"amount\": 1500,\n    \"charged_amount\": 1500\n  }\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "404 Error - unknown db",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Parking database not found\"\n}",
              "status": "Not Found",
              "code": 404
            }
          ]
        },
        {
          "name": "Gateway Callback",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type","value": "application/json"},
              {"key": "X-Internal-Secret","value": "{{PAYMENT_INTERNAL_SECRET}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"req_ref\": \"3fa1c2b4-5678-4abc-9def-0123456789ab\",\n  \"status\": \"SUCCESSFUL\",\n  \"transaction_id\": \"TX123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/payment/callback?db_id=1",
              "host": ["{{base_url}}"],
              "path": ["payment","callback"],
              "query": [{"key": "db_id", "value": "1"}]
            },
            "description": "Called by the itecpay MoMo gateway, not by app clients - included here for documentation/manual testing only. Protected by X-Internal-Secret (PAYMENT_INTERNAL_SECRET, distinct from the social-login secret) as a soft deterrent; the callback body's status is never trusted directly - the handler always re-verifies against itecpay's own verify endpoint before settling anything. Always responds 200 quickly regardless of outcome."
          },
          "response": [
            {
              "name": "200 Received",
              "body": "{\n  \"status\": \"received\"\n}",
              "status": "OK",
              "code": 200
            }
          ]
        }
      ]
    },
