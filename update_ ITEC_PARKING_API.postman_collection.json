{
  "info": {
    "name": "ITEC CLIENT API 2",
    "_postman_id": "b04f2b2b-1105-4427-9371-123456789abc",
    "description": "Postman collection for the ITEC Client API/ITEC Parking API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user1\",\n  \"password\": \"mypassword\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Authenticate user and receive JWT token. `username` accepts a username, email, or phone number; phone-only accounts still require a password to be set via /auth/phone/link/verify or /auth/password/set."
          },
          "response": [
            {
              "name": "Success 200",
              "body": "{\n  \"status\": \"success\",\n  \"token\": \"<JWT_TOKEN>\",\n  \"message\": \"Logged in\"\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "Error 401",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Invalid credentials\"\n}",
              "status": "Unauthorized",
              "code": 401
            }
          ]
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/auth/validate",
              "host": ["{{base_url}}"],
              "path": ["auth", "validate"]
            },
            "description": "Check if the provided JWT token is valid."
          },
          "response": [
            {
              "name": "Success 200",
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"Token is valid\"\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "Error 401",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Invalid or expired token\"\n}",
              "status": "Unauthorized",
              "code": 401
            }
          ]
        },
        {
          "name": "Registration - Initiate",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+250700000001\",\n  \"username\": \"newuser\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register/initiate",
              "host": ["{{base_url}}"],
              "path": ["auth", "register", "initiate"]
            },
            "description": "Initiate user registration, possibly sending an OTP."
          },
          "response": [
            {
              "name": "Success 200",
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"OTP sent\"\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "Error 400",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"User already exists\"\n}",
              "status": "Bad Request",
              "code": 400
            }
          ]
        },
        {
          "name": "Registration - Verify OTP",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+250700000001\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register/verify-otp",
              "host": ["{{base_url}}"],
              "path": ["auth", "register", "verify-otp"]
            },
            "description": "Verify OTP during registration."
          },
          "response": [
            {
              "name": "Success 200",
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"OTP verified\"\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "Error 400",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Invalid or expired OTP\"\n}",
              "status": "Bad Request",
              "code": 400
            }
          ]
        },
        {
          "name": "Registration - Verify Reclaim OTP",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+250700000001\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register/verify-reclaim-otp",
              "host": ["{{base_url}}"],
              "path": ["auth", "register", "verify-reclaim-otp"]
            },
            "description": "Verify reclaim OTP."
          },
          "response": [
            {
              "name": "Success 200",
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"OTP verified for reclaim\"\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "Error 400",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Invalid reclaim OTP\"\n}",
              "status": "Bad Request",
              "code": 400
            }
          ]
        },
        {
          "name": "Registration - Complete",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"password123\",\n  \"other_info\": \"...\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register/complete",
              "host": ["{{base_url}}"],
              "path": ["auth", "register", "complete"]
            },
            "description": "Complete user registration after OTP verification."
          },
          "response": [
            {
              "name": "Success 201",
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"Registration complete\"\n}",
              "status": "Created",
              "code": 201
            },
            {
              "name": "Error 400",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Could not complete registration\"\n}",
              "status": "Bad Request",
              "code": 400
            }
          ]
        },
        {
          "name": "Reclaim - Initiate",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type","value": "application/json"},
              {"key": "Authorization","value": "Bearer {{JWT_TOKEN}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+250700000111\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/phone/reclaim/initiate",
              "host": ["{{base_url}}"],
              "path": ["auth", "phone", "reclaim", "initiate"]
            },
            "description": "Initiate phone reclamation for an authenticated user."
          },
          "response": [
            {
              "name": "Success 200",
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"Reclamation initiated\"\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "Error 401",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Unauthorized\"\n}",
              "status": "Unauthorized",
              "code": 401
            }
          ]
        },
        {
          "name": "Reclaim - Verify",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type","value": "application/json"},
              {"key": "Authorization","value": "Bearer {{JWT_TOKEN}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+250700000111\",\n  \"otp\": \"654321\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/phone/reclaim/verify",
              "host": ["{{base_url}}"],
              "path": ["auth", "phone", "reclaim", "verify"]
            },
            "description": "Verify phone reclamation OTP."
          },
          "response": [
            {
              "name": "Success 200",
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"Phone reclaimed\"\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "Error 401",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Unauthorized or invalid OTP\"\n}",
              "status": "Unauthorized",
              "code": 401
            }
          ]
        },
        {
          "name": "Social Login - Google",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type","value": "application/json"},
              {"key": "X-Internal-Secret","value": "{{INTERNAL_SECRET}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"google\",\n  \"google_id\": \"1234567890\",\n  \"email\": \"user@gmail.com\",\n  \"name\": \"Jane Doe\",\n  \"avatar\": \"https://lh3.googleusercontent.com/...\",\n  \"given_name\": \"Jane\",\n  \"family_name\": \"Doe\",\n  \"id_token\": \"<raw Google ID token - JWT>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/google/callback",
              "host": ["{{base_url}}"],
              "path": ["auth", "google", "callback"]
            },
            "description": "Find-or-create a user from a verified Google sign-in and return a session, same shape as /auth/login. Requires the shared X-Internal-Secret header."
          },
          "response": [
            {
              "name": "Success 200",
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"Signed in successfully.\",\n  \"token\": \"<JWT_TOKEN>\",\n  \"user\": { \"id\": 1, \"email\": \"user@gmail.com\", \"name\": \"Jane Doe\", \"phone\": null },\n  \"requires_phone\": true\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "Error 401 - bad identity",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Could not verify google identity\"\n}",
              "status": "Unauthorized",
              "code": 401
            },
            {
              "name": "Error 401 - missing/invalid internal secret",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Unauthorized\"\n}",
              "status": "Unauthorized",
              "code": 401
            }
          ]
        },
        {
          "name": "Social Login - Facebook",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type","value": "application/json"},
              {"key": "X-Internal-Secret","value": "{{INTERNAL_SECRET}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"facebook\",\n  \"facebook_id\": \"1234567890\",\n  \"email\": \"user@example.com\",\n  \"name\": \"Jane Doe\",\n  \"avatar\": \"https://platform-lookaside.fbsbx.com/...\",\n  \"given_name\": \"Jane\",\n  \"family_name\": \"Doe\",\n  \"access_token\": \"<raw Facebook access token>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/facebook/callback",
              "host": ["{{base_url}}"],
              "path": ["auth", "facebook", "callback"]
            },
            "description": "Find-or-create a user from a verified Facebook sign-in and return a session, same shape as /auth/login. Requires the shared X-Internal-Secret header."
          },
          "response": [
            {
              "name": "Success 200",
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"Signed in successfully.\",\n  \"token\": \"<JWT_TOKEN>\",\n  \"user\": { \"id\": 1, \"email\": \"user@example.com\", \"name\": \"Jane Doe\", \"phone\": null },\n  \"requires_phone\": true\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "Error 401 - bad identity",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Could not verify facebook identity\"\n}",
              "status": "Unauthorized",
              "code": 401
            }
          ]
        },
        {
          "name": "Social Login - Apple",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type","value": "application/json"},
              {"key": "X-Internal-Secret","value": "{{INTERNAL_SECRET}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"apple\",\n  \"apple_id\": \"001234.abcdef...\",\n  \"email\": \"user@privaterelay.appleid.com\",\n  \"name\": \"Jane Doe\",\n  \"id_token\": \"<raw Apple ID token - JWT>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/apple/callback",
              "host": ["{{base_url}}"],
              "path": ["auth", "apple", "callback"]
            },
            "description": "Find-or-create a user from a verified Apple sign-in and return a session, same shape as /auth/login. Apple only sends `name` on the very first authorization; apple_id is the durable identifier. Requires the shared X-Internal-Secret header."
          },
          "response": [
            {
              "name": "Success 200",
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"Signed in successfully.\",\n  \"token\": \"<JWT_TOKEN>\",\n  \"user\": { \"id\": 1, \"email\": \"user@privaterelay.appleid.com\", \"name\": \"Jane Doe\", \"phone\": null },\n  \"requires_phone\": true\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "Error 401 - bad identity",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Could not verify apple identity\"\n}",
              "status": "Unauthorized",
              "code": 401
            }
          ]
        },
        {
          "name": "Phone Link - Initiate",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type","value": "application/json"},
              {"key": "Authorization","value": "Bearer {{JWT_TOKEN}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+250700000001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/phone/link/initiate",
              "host": ["{{base_url}}"],
              "path": ["auth", "phone", "link", "initiate"]
            },
            "description": "Send an OTP to attach a phone number to the authenticated (e.g. social) account. Distinct from /auth/register/*, which creates a new account rather than attaching to an existing one."
          },
          "response": [
            {
              "name": "Success 200",
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"OTP sent successfully\",\n  \"verification_payload\": \"<payload>\",\n  \"expires_in\": 600\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "Error 409 - phone taken",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Phone number already registered\"\n}",
              "status": "Conflict",
              "code": 409
            }
          ]
        },
        {
          "name": "Phone Link - Verify",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type","value": "application/json"},
              {"key": "Authorization","value": "Bearer {{JWT_TOKEN}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+250700000001\",\n  \"otp\": \"123456\",\n  \"password\": \"optional-new-password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/phone/link/verify",
              "host": ["{{base_url}}"],
              "path": ["auth", "phone", "link", "verify"]
            },
            "description": "Verify the OTP, attach the phone as the account's primary number, optionally set a password, and flip requires_phone to false."
          },
          "response": [
            {
              "name": "Success 200",
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"Phone number linked successfully\",\n  \"phone_number\": \"0700000001\",\n  \"requires_phone\": false\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "Error 400 - bad OTP",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Invalid OTP\"\n}",
              "status": "Bad Request",
              "code": 400
            }
          ]
        },
        {
          "name": "Set Password",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type","value": "application/json"},
              {"key": "Authorization","value": "Bearer {{JWT_TOKEN}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"my-new-password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/password/set",
              "host": ["{{base_url}}"],
              "path": ["auth", "password", "set"]
            },
            "description": "Set or replace a password on the authenticated account, independent of phone-link status. No OTP required since the account's email is already provider-verified. Enables /auth/login with email+password afterward."
          },
          "response": [
            {
              "name": "Success 200",
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"Password set successfully\"\n}",
              "status": "OK",
              "code": 200
            },
            {
              "name": "Error 400 - too short",
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"A password of at least 6 characters is required\"\n}",
              "status": "Bad Request",
              "code": 400
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization","value": "Bearer {{JWT_TOKEN}}"}],
            "url": {
              "raw": "{{base_url}}/users/me",
              "host": ["{{base_url}}"],
              "path": ["users","me"]
            },
            "description": "Retrieve the authenticated user's details."
          },
          "response": [
            {
              "name": "200 Success",
              "body": "{ \"id\": 1, \"username\": \"testuser\", \"email\": \"test@example.com\", ... }",
              "status": "OK",
              "code": 200
            },
            {
              "name": "401 Error",
              "body": "{ \"status\": \"error\", \"message\": \"Unauthorized\" }",
              "status": "Unauthorized",
              "code": 401
            }
          ]
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization","value": "Bearer {{JWT_TOKEN}}"}],
            "url": {
              "raw": "{{base_url}}/users/5",
              "host": ["{{base_url}}"],
              "path": ["users","5"]
            },
            "description": "Retrieve another user's details by their ID."
          },
          "response": [
            {
              "name": "200 Success",
              "body": "{ \"id\": 5, \"username\": \"someone\", ... }",
              "status": "OK",
              "code": 200
            },
            {
              "name": "404 Error",
              "body": "{ \"status\": \"error\", \"message\": \"User not found\" }",
              "status": "Not Found",
              "code": 404
            }
          ]
        },
        {
          "name": "Get My Phones",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization","value": "Bearer {{JWT_TOKEN}}"}],
            "url": {
              "raw": "{{base_url}}/users/me/phones",
              "host": ["{{base_url}}"],
              "path": ["users","me","phones"]
            },
            "description": "Retrieve all phone numbers linked to the authenticated user."
          },
          "response": [
            {
              "name": "200 Success",
              "body": "{ \"phones\": [\"+25070000...\", \"+2507123...\"] }",
              "status": "OK",
              "code": 200
            }
          ]
        },
        {
          "name": "Add Phone Number",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type","value": "application/json"},
              {"key": "Authorization","value": "Bearer {{JWT_TOKEN}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"phone\": \"+250700001111\" }"
            },
            "url": {
              "raw": "{{base_url}}/users/me/phones",
              "host": ["{{base_url}}"],
              "path": ["users","me","phones"]
            },
            "description": "Bind a new phone number to the authenticated user."
          },
          "response": [
            {
              "name": "201 Created",
              "body": "{ \"status\": \"success\", \"message\": \"Phone added\" }",
              "status": "Created",
              "code": 201
            },
            {
              "name": "400 Error",
              "body": "{ \"status\": \"error\", \"message\": \"Phone already exists\" }",
              "status": "Bad Request",
              "code": 400
            }
          ]
        },
        {
          "name": "Initiate Phone Verification",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type","value": "application/json"},
              {"key": "Authorization","value": "Bearer {{JWT_TOKEN}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"phone\": \"+250700001234\" }"
            },
            "url": {
              "raw": "{{base_url}}/users/phone/verify/initiate",
              "host": ["{{base_url}}"],
              "path": ["users","phone","verify","initiate"]
            }
          }
        },
        {
          "name": "Complete Phone Verification",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type","value": "application/json"},
              {"key": "Authorization","value": "Bearer {{JWT_TOKEN}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"phone\": \"+250700001234\", \"otp\": \"567890\" }"
            },
            "url": {
              "raw": "{{base_url}}/users/phone/verify/complete",
              "host": ["{{base_url}}"],
              "path": ["users","phone","verify","complete"]
            }
          }
        },
        {
          "name": "Delete Phone Number",
          "request": {
            "method": "DELETE",
            "header": [
              {"key": "Authorization","value": "Bearer {{JWT_TOKEN}}"}
            ],
            "url": {
              "raw": "{{base_url}}/users/me/phones/10",
              "host": ["{{base_url}}"],
              "path": ["users","me","phones","10"]
            },
            "description": "Delete phone number with ID 10 for the authenticated user."
          },
          "response": [
            {
              "name": "200 Success",
              "body": "{ \"status\": \"success\", \"message\": \"Phone removed\" }",
              "status": "OK",
              "code": 200
            },
            {
              "name": "404 Error",
              "body": "{ \"status\": \"error\", \"message\": \"Phone not found\" }",
              "status": "Not Found",
              "code": 404
            }
          ]
        }
      ]
    },
